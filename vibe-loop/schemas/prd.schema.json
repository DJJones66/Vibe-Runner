{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vibe Runner PRD",
  "type": "object",
  "required": [
    "project",
    "version",
    "updated_at",
    "notes",
    "tasks"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "object",
      "required": [
        "definition_of_done"
      ],
      "properties": {
        "definition_of_done": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "priority",
          "status",
          "depends_on",
          "prompt",
          "acceptance",
          "validation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "retry",
              "done",
              "failed",
              "blocked"
            ]
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validation": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
